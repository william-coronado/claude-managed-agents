sequenceDiagram
    actor User
    participant Orchestrate as orchestrate_main
    participant ContentRun as content_creator_main
    participant SERun as se_main
    participant Loader as load_resources
    participant Env as create_environment
    participant Agent as create_agent

    User ->> Orchestrate: run_orchestrate_with_existing
    Orchestrate ->> Loader: load_resources(client, cfg, env_config_path, agent_config_path, existing=True)

    User ->> ContentRun: run_content_creator_with_existing
    ContentRun ->> Loader: load_resources(client, cfg, env_config_path, agent_config_path, existing=True)

    User ->> SERun: run_software_engineering_with_existing
    SERun ->> Loader: load_resources(client, cfg, env_config_path, agent_config_path, existing=True)

    Loader ->> Env: create_environment(client, env_config, existing=True)
    alt environment_not_found
        Env -->> Loader: raise ResourceNotFoundError
        Loader -->> Orchestrate: raise SystemExit
        Loader -->> ContentRun: raise SystemExit
        Loader -->> SERun: raise SystemExit
        Orchestrate -->> User: exit_with_error_message
        ContentRun -->> User: exit_with_error_message
        SERun -->> User: exit_with_error_message
    else environment_found
        Env -->> Loader: Environment
        Loader ->> Agent: create_agent(client, agent_config, default_model, existing=True)
        alt agent_not_found
            Agent -->> Loader: raise ResourceNotFoundError
            Loader -->> Orchestrate: raise SystemExit
            Loader -->> ContentRun: raise SystemExit
            Loader -->> SERun: raise SystemExit
            Orchestrate -->> User: exit_with_error_message
            ContentRun -->> User: exit_with_error_message
            SERun -->> User: exit_with_error_message
        else agent_found
            Agent -->> Loader: Agent
            Loader -->> Orchestrate: envs_dict, agents_dict
            Loader -->> ContentRun: envs_dict, agents_dict
            Loader -->> SERun: envs_dict, agents_dict
            Orchestrate -->> User: start_single_agent_orchestration
            ContentRun -->> User: start_content_creator_pipeline
            SERun -->> User: start_software_engineering_pipeline
        end
    end
