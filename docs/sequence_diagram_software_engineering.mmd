sequenceDiagram
    actor User
    participant SE as software_engineering.main
    participant CL as config_loader
    participant A as AnthropicClient
    participant L as load_resources
    participant P as run_agent_step
    participant S as create_session
    participant M as stream_message

    User ->> SE: python use_cases/software_engineering/run.py --task [--existing]
    SE ->> CL: load_global_config(config)
    CL -->> SE: GlobalConfig
    SE ->> A: Anthropic(api_key)
    SE ->> L: load_resources(client, default_model, ENV_CONFIG, AGENT_CONFIG, existing)
    L -->> SE: envs_dict, agents_dict

    SE ->> P: run_agent_step(se-planner, se-env, plan_prompt)
    P ->> S: create_session(...)
    P ->> M: stream_message(...)
    M -->> P: plan_output
    P -->> SE: plan_output

    SE ->> P: run_agent_step(se-coder, se-env, prompt + plan_output)
    P ->> S: create_session(...)
    P ->> M: stream_message(...)
    M -->> P: code_output
    P -->> SE: code_output

    SE ->> P: run_agent_step(se-reviewer, se-env, prompt + code_output)
    P ->> S: create_session(...)
    P ->> M: stream_message(...)
    M -->> P: review_output
    P -->> SE: review_output

    SE ->> P: run_agent_step(se-tester, se-env, prompt + code_output + review_output)
    P ->> S: create_session(...)
    P ->> M: stream_message(...)
    M -->> P: test_output
    P -->> SE: test_output

    SE -->> User: tester output streamed
