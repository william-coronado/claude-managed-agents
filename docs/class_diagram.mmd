classDiagram
    class LookupError

    class ResourceNotFoundError {
        +"Raised when existing resource is missing"
    }
    ResourceNotFoundError --|> LookupError

    class GlobalConfig {
        +api_key: str
        +default_model: str
        +environments_config: str
        +agents_config: str
    }

    class EnvironmentConfig {
        +name: str
        +description: str
        +config: dict
    }

    class AgentConfig {
        +name: str
        +system: str
        +model: Optional[str]
        +description: str
        +tools: list
        +mcp_servers: list
        +skills: list
    }

    class config_loader {
        +load_global_config(path) GlobalConfig
        +load_environments_config(path) list~EnvironmentConfig~
        +load_agents_config(path) list~AgentConfig~
    }

    class Environment {
        -_obj
        +id
        +name
        +__init__(api_obj)
    }

    class Agent {
        -_obj
        +id
        +name
        +__init__(api_obj)
    }

    class Session {
        -_obj
        +id
        +__init__(api_obj)
    }

    class environment_module {
        +create_environment(client, config, existing=False) Environment
    }

    class agent_module {
        +create_agent(client, config, default_model, existing=False) Agent
    }

    class session_module {
        +create_session(client, agent_id, environment_id, title=None) Session
    }

    class messaging_module {
        +stream_message(client, session_id, text) str
    }

    class loader_module {
        +load_resources(client, default_model, env_config_path, agent_config_path, existing=False) tuple
    }

    class pipeline_module {
        +run_agent_step(client, agents, envs, agent_name, env_name, prompt) str
    }

    class orchestrate_main {
        +main()
    }

    class se_main {
        +main()
    }

    class cc_main {
        +main()
    }

