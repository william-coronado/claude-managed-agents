sequenceDiagram
    actor User
    participant C as content_creator.main
    participant CL as config_loader
    participant A as AnthropicClient
    participant L as load_resources
    participant P as run_agent_step
    participant S as create_session
    participant M as stream_message

    User ->> C: python use_cases/content_creator/run.py --topic [--existing]
    C ->> CL: load_global_config(config)
    CL -->> C: GlobalConfig
    C ->> A: Anthropic(api_key)
    C ->> L: load_resources(client, default_model, ENV_CONFIG, AGENT_CONFIG, existing)
    L -->> C: envs_dict, agents_dict

    C ->> P: run_agent_step(cc-researcher, cc-env, research_prompt)
    P ->> S: create_session(...)
    P ->> M: stream_message(...)
    M -->> P: research_output
    P -->> C: research_output

    C ->> P: run_agent_step(cc-author, cc-env, prompt + research_output)
    P ->> S: create_session(...)
    P ->> M: stream_message(...)
    M -->> P: article_output
    P -->> C: article_output

    C ->> P: run_agent_step(cc-editor, cc-env, prompt + article_output)
    P ->> S: create_session(...)
    P ->> M: stream_message(...)
    M -->> P: final_output
    P -->> C: final_output

    C -->> User: final edited article
